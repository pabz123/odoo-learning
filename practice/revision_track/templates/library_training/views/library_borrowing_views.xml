<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_borrowing_tree" model="ir.ui.view">
        <field name="name">library.borrowing.tree</field>
        <field name="model">library.borrowing</field>
        <field name="arch" type="xml">
            <list>
                <field name="book_id"/>
                <field name="borrower_id"/>
                <field name="borrow_date"/>
                <field name="due_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_library_borrowing_form" model="ir.ui.view">
        <field name="name">library.borrowing.form</field>
        <field name="model">library.borrowing</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="book_id"/>
                        <field name="borrower_id"/>
                        <field name="borrow_date"/>
                        <field name="due_date"/>
                        <field name="returned_at"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_library_borrowing" model="ir.actions.act_window">
        <field name="name">Borrowings</field>
        <field name="res_model">library.borrowing</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
