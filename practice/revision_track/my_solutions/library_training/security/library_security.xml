<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<!-- Group hierarchy: manager -> library user -> internal user -->
	<record id="group_library_user" model="res.groups">
		<field name="name">Library User</field>
		<field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
	</record>

	<record id="group_library_manager" model="res.groups">
		<field name="name">Library Manager</field>
		<field name="implied_ids" eval="[(4, ref('library_training.group_library_user'))]"/>
	</record>

	<!-- Book rules -->
	<!-- User can only read books from allowed companies (operation-level deny for write/create/unlink). -->
	<record id="library_book_rule_user_multicompany_readonly" model="ir.rule">
		<field name="name">Library Book User Multi-company (Read-only)</field>
		<field name="model_id" ref="model_library_book"/>
		<field name="groups" eval="[(4, ref('library_training.group_library_user'))]"/>
		<field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
		<field name="perm_read" eval="1"/>
		<field name="perm_write" eval="0"/>
		<field name="perm_create" eval="0"/>
		<field name="perm_unlink" eval="0"/>
	</record>

	<record id="library_book_rule_manager_all" model="ir.rule">
		<field name="name">Library Book Manager All</field>
		<field name="model_id" ref="model_library_book"/>
		<field name="groups" eval="[(4, ref('library_training.group_library_manager'))]"/>
		<field name="domain_force">[(1, '=', 1)]</field>
		<field name="perm_read" eval="1"/>
		<field name="perm_write" eval="1"/>
		<field name="perm_create" eval="1"/>
		<field name="perm_unlink" eval="1"/>
	</record>

	<!-- Borrowing rules -->
	<!-- User can access borrowings in allowed companies and only their own/linked partner records. -->
	<record id="library_borrowing_rule_user_own_or_partner" model="ir.rule">
		<field name="name">Library Borrowing User Own or Linked Partner</field>
		<field name="model_id" ref="model_library_borrowing"/>
		<field name="groups" eval="[(4, ref('library_training.group_library_user'))]"/>
		<field name="domain_force">
			[
				'&amp;',
					'|', ('company_id', '=', False), ('company_id', 'in', company_ids),
					'|', ('create_uid', '=', user.id), ('borrower_id.user_ids', 'in', [user.id])
			]
		</field>
		<field name="perm_read" eval="1"/>
		<field name="perm_write" eval="1"/>
		<field name="perm_create" eval="1"/>
		<field name="perm_unlink" eval="0"/>
	</record>

	<record id="library_borrowing_rule_manager_all" model="ir.rule">
		<field name="name">Library Borrowing Manager All</field>
		<field name="model_id" ref="model_library_borrowing"/>
		<field name="groups" eval="[(4, ref('library_training.group_library_manager'))]"/>
		<field name="domain_force">[(1, '=', 1)]</field>
		<field name="perm_read" eval="1"/>
		<field name="perm_write" eval="1"/>
		<field name="perm_create" eval="1"/>
		<field name="perm_unlink" eval="1"/>
	</record>
</odoo>
